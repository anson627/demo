%% Diagram 1: Architecture Overview with Network Stack Integration
%% Shows the complete DNS infrastructure including GPU nodes, NodeLocal DNSCache,
%% CoreDNS deployment, network stack layers, and connections to Azure Blob Storage
%% and specialized networks. Merged with network stack detail from Diagram 5.

graph TB
    subgraph "Kubernetes Services"
        CDSVC[CoreDNS Service<br/>kube-dns 10.0.0.10]
        CD1[CoreDNS Pod 1<br/>8GB/4CPU]
        CD2[CoreDNS Pod 2<br/>8GB/4CPU]
        CD3[CoreDNS Pod 3<br/>8GB/4CPU]
        KR[Kube-Ray<br/>Head Service]
        MPI[Headless Service]

        CDSVC --> CD1 & CD2 & CD3
    end

    subgraph "Azure DNS"
        BLOB_DNS[DNS: *.blob.core.windows.net]
    end

    subgraph "Azure Blob"
        BLOB1[Stamp 1<br/>10.64.2.188]
        BLOB2[Stamp 2<br/>10.64.2.189]
        BLOB3[Stamp 3<br/>10.64.2.190]
    end

    subgraph "GPU Nodes (1..N)"
        APP[Ray Actor/Task<br/>PyTorch Framework<br/>NCCL Library]
        IMEX[IMEX Channel<br/>Intra-Rack]
        RDMA[RDMA Channel<br/>Cross-Rack]
        NLD[NodeLocal Cache<br/>169.254.20.10<br/>TTL: 30s-5m]

        APP -->|DNS Resolution| NLD
        APP --> IMEX
        APP --> RDMA
    end

    BLOB_DNS --> BLOB1 & BLOB2 & BLOB3
    NLD -->|DNS Transport over TCP| CDSVC

    subgraph "Physical Network"
        NVL[NVLink/NVSwitch<br/>900GB/s-1.8TB/s<br/>Intra-Rack]
        IB[InfiniBand<br/>400Gb/s-800Gb/s<br/>Cross-Rack]
    end

    APP --> KR & MPI
    NLD --> BLOB_DNS
    IMEX --> NVL
    RDMA --> IB

    style APP fill:#90EE90
    style NLD fill:#87CEEB
    style CD1 fill:#DDA0DD
    style CD2 fill:#DDA0DD
    style CD3 fill:#DDA0DD
    style BLOB1 fill:#F0E68C
    style BLOB2 fill:#F0E68C
    style BLOB3 fill:#F0E68C
    style BLOB_DNS fill:#87CEEB
    style NVL fill:#FFB6C1
    style IB fill:#FFA07A
