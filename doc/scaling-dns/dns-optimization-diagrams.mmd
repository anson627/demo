%% ========================================
%% DNS Optimization Diagrams for LLM Training on AKS
%% ========================================

%% Diagram 1: Architecture Overview
%% Shows the complete DNS infrastructure including GPU nodes, NodeLocal DNSCache,
%% CoreDNS deployment, and connections to Azure Blob Storage and specialized networks

graph TB
    subgraph "GPU Node 1..N (Thousands of Nodes)"
        subgraph "Training Pod"
            TP1[Training Worker Pod<br/>GPU: GB200]
            TP1_LIB[NCCL Library<br/>All-Gather/All-Reduce]
            TP1 --> TP1_LIB
        end

        subgraph "NodeLocal DNS Cache"
            NLD[NodeLocal DNSCache<br/>169.254.20.10<br/>Cache: 30s-5m TTL]
        end

        TP1 -->|DNS Query<br/>169.254.20.10| NLD
    end

    subgraph "Control Plane"
        subgraph "CoreDNS Deployment"
            CD1[CoreDNS Pod 1<br/>8GB RAM<br/>4 CPU]
            CD2[CoreDNS Pod 2<br/>8GB RAM<br/>4 CPU]
            CD3[CoreDNS Pod N<br/>8GB RAM<br/>4 CPU]
            CDSVC[CoreDNS Service<br/>kube-dns<br/>10.0.0.10]
        end

        NLD -->|Cache Miss| CDSVC
        CDSVC --> CD1
        CDSVC --> CD2
        CDSVC --> CD3

        subgraph "Job Orchestration"
            KR[Kube-Ray Operator<br/>Head Service]
            MPI[Kubeflow MPI Operator<br/>Launcher Service]
        end
    end

    subgraph "Azure Services"
        BLOB[Azure Blob Storage<br/>Training Data<br/>Checkpoints<br/>*.blob.core.windows.net]
    end

    subgraph "Specialized Network"
        NVL[NVLink/NVSwitch<br/>Intra-Rack IMEX<br/>900GB/s-1.8TB/s]
        IB[InfiniBand RDMA<br/>Cross-Rack<br/>400Gb/s-800Gb/s]
    end

    TP1 -->|Service Discovery| KR
    TP1 -->|Service Discovery| MPI
    TP1 -->|Data/Checkpoint I/O<br/>DNS: *.blob.core.windows.net| BLOB
    TP1_LIB -->|Collective Ops| NVL
    TP1_LIB -->|Collective Ops| IB

    style TP1 fill:#90EE90
    style NLD fill:#87CEEB
    style CD1 fill:#DDA0DD
    style CD2 fill:#DDA0DD
    style CD3 fill:#DDA0DD
    style BLOB fill:#F0E68C
    style NVL fill:#FFB6C1
    style IB fill:#FFB6C1


%% ========================================
%% Diagram 2: The Autoscaling Problem
%% Illustrates why HPA fails for bursty LLM training workloads - the burst happens
%% too quickly for autoscaling to react, leading to cascading failures

graph TB
    subgraph "The Autoscaling Problem"
        A[Training Job Starts<br/>5000 Pods Launch] --> B[Massive DNS Burst<br/>25000+ queries in 5 seconds]
        B --> C[CoreDNS Overwhelmed<br/>3 replicas @ 100% CPU]
        C --> D[Queries Timeout<br/>5-30 second delays]
        D --> E[HPA Detects High CPU<br/>After 15-30s]
        E --> F[New CoreDNS Pods Launching<br/>60-90s to ready]
        F --> G[TOO LATE<br/>Training pods already failed]

        H[Meanwhile: conntrack table] --> I[Thousands of connections<br/>to 3 CoreDNS IPs]
        I --> J[Conntrack table full<br/>nf_conntrack: table full]
        J --> K[New connections dropped<br/>Additional failures]
    end

    style A fill:#FFB6C1
    style B fill:#FF6B6B
    style D fill:#FF0000
    style G fill:#FF0000
    style J fill:#FF0000


%% ========================================
%% Diagram 3: NodeLocal DNS Solution Comparison
%% Side-by-side comparison showing how NodeLocal DNSCache solves the DNS scaling
%% problem by absorbing 95% of queries locally, eliminating conntrack exhaustion

graph TB
    subgraph "Without NodeLocal DNS"
        W1[5000 Training Pods] --> W2[25000 DNS queries/sec]
        W2 --> W3[CoreDNS Service<br/>3 backend pods]
        W3 --> W4[Problems]
        W4 --> W5[Conntrack: 3000+ entries per node]
        W4 --> W6[Per-pod load: 1666 QPS]
        W4 --> W7[Timeouts & failures]
    end

    subgraph "With NodeLocal DNS"
        N1[5000 Training Pods] --> N2[25000 DNS queries/sec]
        N2 --> N3[NodeLocal DNS<br/>169.254.20.10<br/>1 per node]
        N3 --> N4[95% Cache Hit]
        N4 --> N5[Only 250 queries<br/>reach CoreDNS]
        N5 --> N6[CoreDNS Service<br/>3 pods = 83 QPS each]

        N3 --> N7[Benefits]
        N7 --> N8[No conntrack entries<br/>direct to 169.254.20.10]
        N7 --> N9[Sub-millisecond latency<br/>local cache hits]
        N7 --> N10[No DNS timeouts]
    end

    style W4 fill:#FF6B6B
    style W7 fill:#FF0000
    style N4 fill:#90EE90
    style N9 fill:#90EE90


%% ========================================
%% Diagram 4: LLM Training Workflow Sequence
%% Sequential flow of DNS queries through a complete training job lifecycle,
%% from initial pod startup through training to node churn scenarios

sequenceDiagram
    participant Scheduler as Kubernetes Scheduler
    participant Pod as Training Pod (1 of 5000)
    participant NLD as NodeLocal DNS<br/>169.254.20.10
    participant CoreDNS as CoreDNS Service
    participant RayHead as Ray Head Service
    participant Blob as Azure Blob Storage

    Note over Scheduler,Blob: Phase 1: Job Startup (T=0s)

    Scheduler->>Pod: Schedule pod to GPU node
    Pod->>Pod: Container starts
    Pod->>NLD: Query: ray-head-svc.kuberay-system.svc.cluster.local
    NLD->>NLD: Cache MISS (first query)
    NLD->>CoreDNS: Forward query (TCP)
    CoreDNS->>CoreDNS: Kubernetes plugin lookup
    CoreDNS->>NLD: Return: 10.0.45.123
    NLD->>NLD: Cache entry (TTL: 30s)
    NLD->>Pod: Return: 10.0.45.123

    Note over Pod,RayHead: Pods 2-5000 query simultaneously

    Pod->>NLD: Query: *.blob.core.windows.net
    NLD->>NLD: Cache MISS
    NLD->>CoreDNS: Forward query
    CoreDNS->>CoreDNS: External DNS forward
    CoreDNS->>NLD: Return: 20.38.47.52
    NLD->>NLD: Cache entry (TTL: 300s)
    NLD->>Pod: Return: 20.38.47.52

    Pod->>RayHead: Connect to Ray cluster
    Pod->>Blob: Load training data

    Note over Scheduler,Blob: Phase 2: Training (T=60s - hours)

    Pod->>NLD: Query: ray-head-svc (TTL expired)
    NLD->>NLD: Prefetch triggered at 75% TTL
    NLD->>Pod: Return: 10.0.45.123 (from cache)
    NLD->>CoreDNS: Background refresh query

    Pod->>NLD: Query: *.blob.core.windows.net
    NLD->>NLD: Cache HIT (5min TTL)
    NLD->>Pod: Return: 20.38.47.52 (<1ms)

    Pod->>Blob: Save checkpoint

    Note over Scheduler,Blob: Phase 3: Node Churn (T=2h)

    Note over Pod: Node failure, pod rescheduled
    Scheduler->>Pod: Reschedule to new GPU node
    Pod->>NLD: Query: ray-head-svc
    NLD->>NLD: Cache MISS (new node)
    NLD->>CoreDNS: Forward query
    CoreDNS->>CoreDNS: Cache HIT (cached in CoreDNS)
    CoreDNS->>NLD: Return: 10.0.45.123 (fast)
    NLD->>Pod: Rejoin training


%% ========================================
%% Diagram 5: Network Stack Integration
%% Complete network stack showing how DNS discovery integrates with the specialized
%% high-performance networks (NVLink/InfiniBand) used for training communication

graph TB
    subgraph "Pod Network Layers"
        APP[Training Application<br/>PyTorch/JAX/TF]

        subgraph "Service Discovery"
            DNS[DNS Resolution<br/>NodeLocal + CoreDNS]
        end

        subgraph "Collective Communication"
            NCCL[NCCL Library<br/>All-Gather/All-Reduce/Broadcast]
        end

        subgraph "Transport Selection"
            IMEX[IMEX Plugin<br/>Intra-Rack]
            RDMA[RDMA Plugin<br/>Cross-Rack]
        end

        subgraph "Physical Network"
            NVL[NVLink/NVSwitch<br/>900GB/s-1.8TB/s<br/>Within Rack]
            IB[InfiniBand<br/>400Gb/s-800Gb/s<br/>Across Racks]
        end

        APP --> DNS
        DNS -.->|Discovers Peers| NCCL
        APP --> NCCL
        NCCL --> IMEX
        NCCL --> RDMA
        IMEX --> NVL
        RDMA --> IB
    end

    subgraph "Storage I/O"
        BLOB_DNS[Blob Storage DNS<br/>*.blob.core.windows.net]
        BLOB_CONN[HTTPS Connection<br/>Training Data/Checkpoints]
        BLOB_STORAGE[(Azure Blob Storage<br/>Hierarchical Namespace)]

        APP --> BLOB_DNS
        BLOB_DNS -.->|Resolves Endpoint| BLOB_CONN
        BLOB_CONN --> BLOB_STORAGE
    end

    style DNS fill:#87CEEB
    style NCCL fill:#90EE90
    style NVL fill:#FFB6C1
    style IB fill:#FFA07A
    style BLOB_DNS fill:#87CEEB
