%%{init: {'themeVariables': {'background': '#294751', 'lineColor': '#e0f2ff'}}}%%
graph TB
    CP[K8s Control Plane]
    CL2[clusterloader2]

    subgraph cp_cluster["K8s CPU Nodes"]
        subgraph node1["Node 1"]
            KRO[kuberay-operator]
            MRH[mock-ray-head]
        end

        subgraph node2["Node 2"]
            KC[kwok-controller]
        end

        subgraph node3["Node 3"]
            PG[prometheus/grafana]
        end
    end

    subgraph gpu_cluster["Virtual GPU Nodes (kwok)"]
        GPU1[kwok-gpu-node-1]
        GPU2[kwok-gpu-node-2]
        GPUN[kwok-gpu-node-n...]
    end

    %% Job submission
    CL2 -.->|submit rayjob & raycluster| CP

    %% Control plane interactions (grouped together)
    KRO -.->|reconcile rayjob & raycluster| CP
    KC -.->|simulate node & pod lifecycle| CP
    CP -.->|assign pods| GPU1
    CP -.->|assign pods| GPU2
    CP -.->|assign pods| GPUN

    %% Node lifecycle management
    GPU1 -.->|lease update| CP
    GPU2 -.->|lease update| CP
    GPUN -.->|lease update| CP

    %% Job management (separate section)
    KRO -.->|jobs info| MRH
    MRH -.->|jobs status| KRO

    %% Metrics collection
    PG -.->|scrape metrics| KRO
    PG -.->|scrape metrics| CP

    classDef controlPlane fill:#e1f5fe
    classDef cpuNode fill:#1f3a5b,stroke:#7fb3d5,color:#e0f2ff
    classDef gpuNode fill:#184040,stroke:#5fb0b5,color:#e0f2ff
    classDef workload fill:#fff3e0
    classDef component fill:#fce4ec

    class CP controlPlane
    class KRO,KC,MRH,PG component
    class GPU1,GPU2,GPUN gpuNode
    class CL2 workload

    style cp_cluster fill:#123652,stroke:#7fb3d5,color:#e0f2ff
    style gpu_cluster fill:#0f3b3b,stroke:#5fb0b5,color:#e0f2ff
    style node1 fill:#0f2740,stroke:#7fb3d5,color:#e0f2ff
    style node2 fill:#0f2740,stroke:#7fb3d5,color:#e0f2ff
    style node3 fill:#0f2740,stroke:#7fb3d5,color:#e0f2ff
