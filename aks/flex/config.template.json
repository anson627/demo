{
  "azure": {
    "subscriptionId": "${SUBSCRIPTION}",
    "tenantId": "${TENANT_ID}",
    "servicePrincipal": {
      "tenantId": "${TENANT_ID}",
      "clientId": "${MY_SP_ID}",
      "clientSecret": "${MY_SP_SECRET}"
    },
    "cloud": "AzurePublicCloud",
    "targetCluster": {
      "resourceId": "${AKS_RESOURCE_ID}",
      "location": "${LOCATION}"
    }
  },
  "kubernetes": {
    "version": "1.34.1"
  },
  "agent": {
    "logLevel": "info",
    "logDir": "/var/log/aks-flex-node"
  }
}
